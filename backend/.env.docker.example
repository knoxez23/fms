APP_NAME=FarmlyAPI
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.example.com
APP_TIMEZONE=Africa/Nairobi

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=farmly
DB_USERNAME=farmly
DB_PASSWORD=change-me

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SANCTUM_STATEFUL_DOMAINS=
SESSION_DOMAIN=
FRONTEND_URL=https://app.example.com

MAIL_MAILER=log
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Farmly API"

SENTRY_LARAVEL_DSN=
